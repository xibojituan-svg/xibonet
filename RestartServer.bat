@echo off
title Xibo DSTE .NET 服务重启工具
color 0A

echo ========================================================
echo     [Xibo成长系统] 正在检测端口 5000 的旧服务进程...
echo ========================================================

:: 查找占用 5000 端口的进程PID并强制杀除
for /f "tokens=5" %%a in ('netstat -aon ^| find "5000" ^| find "LISTENING"') do (
    echo [发现进程] 正在强制关闭 PID: %%a
    taskkill /F /PID %%a
)

echo.
echo ========================================================
echo     正在启动崭新的 .NET Kestrel 服务，请稍候...
echo ========================================================

:: 跳转到当前脚本所在的目录 (也就是 D:\xibo2026Net)
cd /d "%~dp0"

:: 启动项目 (强行绑定所有网卡，允许局域网访问)
dotnet run --urls="http://0.0.0.0:5000"

:: 如果意外退出，暂停窗口以供查看
pause
